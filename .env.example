# Copy to .env and fill in real values.
# .env is git-ignored and must NEVER be committed.
# On the server, place the filled-in file at /opt/vt-clickfix-vmray/.env

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=vt-clickfix-vmray
APP_ENV=production

# ── Database (service-internal — change only if you override the DB service) ─
DATABASE_URL=postgresql+asyncpg://app:app@db:5432/app

# ── VirusTotal ────────────────────────────────────────────────────────────────
# Obtain from https://www.virustotal.com/gui/my-apikey
# Leave empty to run without VT integration (app stays healthy).
VT_API_KEY=

# VT polling interval in seconds (default: 300)
VT_POLL_INTERVAL_SECONDS=300

# Set to true to enable the VT scheduler job
VT_ENABLED=false

# ── VMRay ─────────────────────────────────────────────────────────────────────
# Your VMRay Cloud instance base URL, e.g. https://cloud.vmray.com
VMRAY_URL=

# API key from VMRay Web Interface → API Keys
VMRAY_API_KEY=

# VMRay polling interval in seconds (default: 60)
VMRAY_POLL_INTERVAL_SECONDS=60

# Set to true to enable VMRay scheduler jobs
VMRAY_ENABLED=false

# ── Pipeline ──────────────────────────────────────────────────────────────────
# Set to true to start the APScheduler on app startup.
# Requires VT_ENABLED and/or VMRAY_ENABLED to actually schedule jobs.
PIPELINE_AUTOSTART=false
